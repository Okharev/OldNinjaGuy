{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "f1feaa0dc96f4ef1889ed80a485676cb",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "CalculateHalftoneHole (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": 50.400054931640628,
            "y": 672.7999877929688,
            "width": 143.199951171875,
            "height": 44.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "795b56e1af4649d18e26a3558a4a965e"
        },
        {
            "m_Id": "f875a2ab135e4a00885a479eae4dacdb"
        },
        {
            "m_Id": "87eb3fc237cf466e8fa83fa0ff505047"
        },
        {
            "m_Id": "f1970bbe9dfb4271b1318b69a998a413"
        },
        {
            "m_Id": "af0c987069744c6aa9540ff66b595d65"
        },
        {
            "m_Id": "f6230749973e4cb980aa68ace59a990e"
        },
        {
            "m_Id": "391ea48dd1104e0386d3b2f6ed1cc8ac"
        },
        {
            "m_Id": "1b67eb50baf04dfa80c5fdaddbb303bc"
        },
        {
            "m_Id": "9fb8d15f85444e9cbfbb590cf9e10ffd"
        },
        {
            "m_Id": "a54a6548e1a647c7a4fe5eebaacd929f"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "CalculateHalftoneHole",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "// 1. Convert Player 3D Position to 2D Screen Space safely\r\nfloat4 playerHCS = mul(GetWorldToHClipMatrix(), float4(PlayerPos, 1.0));\r\nfloat2 playerUV = (playerHCS.xy / playerHCS.w) * 0.5 + 0.5;\r\n\r\n// Handle differences in graphics APIs (DirectX vs OpenGL/Vulkan)\r\n#if UNITY_UV_STARTS_AT_TOP\r\nplayerUV.y = 1.0 - playerUV.y;\r\n#endif\r\n\r\n// 2. Get Wall Pixel Screen Space\r\nfloat2 wallUV = ScreenPosition.xy / ScreenPosition.w;\r\n\r\n// 3. Calculate 2D Screen Distance using our new Screen inputs!\r\nfloat2 diff = wallUV - playerUV;\r\ndiff.x *= ScreenWidth / ScreenHeight; \r\nfloat dist2D = length(diff);\r\n\r\n// 4. Depth Occlusion Check using our new Camera input!\r\nfloat distToWall = distance(CameraPos, PixelWorldPos);\r\nfloat distToPlayer = distance(CameraPos, PlayerPos);\r\nbool isOccluding = (distToWall < distToPlayer) && (playerHCS.w > 0.0);\r\n\r\n// 5. Calculate Opacity\r\nfloat opacity = saturate((dist2D - HoleRadius) / DitherWidth);\r\nif (!isOccluding) opacity = 1.0;\r\n\r\n// 6. Halftone Dither Math\r\nfloat2 screenGridUV = wallUV;\r\nscreenGridUV.x *= ScreenWidth / ScreenHeight;\r\nscreenGridUV *= HalftoneScale;\r\n\r\nfloat2 localUV = frac(screenGridUV) - 0.5;\r\nfloat dotThreshold = length(localUV) * 1.414;\r\n\r\n// 7. Output to the Graph\r\nOutAlpha = opacity - dotThreshold;"
}

