<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/Scripts/Dialoue/DialogueUI.uss?fileID=7433441132597879392&amp;guid=cd479a1d3b30de74e96d233a8afdec10&amp;type=3#DialogueUI"/>
    <ui:VisualElement name="BackgroundArt" class="background-art"/>
    <ui:VisualElement name="DialogueContainer" class="dialogue-container">
        <ui:VisualElement name="DialogueBox" class="dialogue-box">
            <ui:Label name="CharacterName" text="Nom du Personnage" class="character-name" style="background-image: none; -unity-background-scale-mode: scale-to-fit;"/>
            <ui:Label name="DialogueText" text="Ceci est un exemple de texte..." class="dialogue-text"/>
            <ui:Button name="ClickZone" class="click-zone"/>
        </ui:VisualElement>
    </ui:VisualElement>
    <ui:VisualElement name="BlackScreen" class="black-screen"/>
</ui:UXML>
