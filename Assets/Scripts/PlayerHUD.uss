.player-health-bg {
    position: absolute;
    top: 30px;
    left: 30px;
    width: 300px;
    height: 30px;
    background-color: rgba(20, 20, 20, 0.9);
    border-radius: 5px;
    border-width: 3px;
    border-color: #111111;
}

.player-health-fill {
    height: 100%;
    width: 100%;
    background-color: #2ecc71; /* A nice, vibrant green */
    border-radius: 2px;
    transition: width 0.2s ease-out-bounce; /* Snappy, bouncy hit reaction */
}